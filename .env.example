# J & R Construction Manager — environment (copy to .env locally; never commit .env)
#
# BUSINESS FILES LIVE IN DROPBOX — NOT GITHUB.
# GitHub = application source only. Dropbox = jobs, quotes, receipts, payroll, tax.

# --- Local Dropbox sync (office Windows PC) ---
# Path to office dropbox-records (Office Assistant source of truth)
JRC_DROPBOX_RECORDS=c:\Users\enrag\projects\JRC-Construction-Office\dropbox-records

# Main business folder on a synced PC
JRC_DROPBOX_BUSINESS_ROOT=C:\Users\enrag\Dropbox\All Files\JRC_COMPLETE_BUSINESS_FOLDER_2026-06-22\JRC_COMPLETE_BUSINESS_FOLDER_2026-06-22

# --- Cloud agent / Cursor (no local Dropbox sync) ---
# Create a Dropbox app at https://www.dropbox.com/developers/apps
# Generate an access token with files.metadata.read, files.content.read, and files.content.write
# Add DROPBOX_ACCESS_TOKEN to Cursor → Settings → Cloud Agents → Secrets (not GitHub)
DROPBOX_ACCESS_TOKEN=

# Optional API path prefix inside your Dropbox account
# Examples: /dropbox-records  or  /JRC_COMPLETE_BUSINESS_FOLDER_2026-06-22
DROPBOX_API_ROOT=/dropbox-records

# Local cache when using API (gitignored)
JRC_DROPBOX_MIRROR=./dropbox-business
