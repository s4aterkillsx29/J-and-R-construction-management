# J & R Construction Manager — environment (copy to .env locally; never commit .env)
#
# ONE WORKSPACE — all business files under a single Dropbox folder.
# GitHub = application source only.

# Primary: unified business workspace (phone Cursor + Manager + office CSVs)
JRC_WORKSPACE_ROOT=C:\Users\enrag\Dropbox\All Files\JRC_COMPLETE_BUSINESS_FOLDER_2026-06-22\JRC_COMPLETE_BUSINESS_FOLDER_2026-06-22

# Legacy aliases (same folder — kept for older scripts)
JRC_DROPBOX_BUSINESS_ROOT=%JRC_WORKSPACE_ROOT%
JRC_DROPBOX_RECORDS=%JRC_WORKSPACE_ROOT%

# Cloud agent API (optional — when no local Dropbox sync)
DROPBOX_ACCESS_TOKEN=
DROPBOX_API_ROOT=/JRC_COMPLETE_BUSINESS_FOLDER_2026-06-22
JRC_DROPBOX_MIRROR=./dropbox-business
