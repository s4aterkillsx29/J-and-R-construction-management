*_REPORT.txt
PROJECT_LOG.txt
INSTALL_SETUP_REPORT.txt
PHASE_VERIFICATION_REPORT.txt
PROGRAM_UPDATE_REPORT.txt
LIVE_RELEASE_VERIFY_REPORT.txt

# Runtime exports (may contain LAN IPs, session metadata, local paths)
exports/

# Dropbox business records — not part of app source
dropbox-records/

# Business standards runtime manifest (local paths synced from Dropbox)
business_standards/OFFICE_STANDARDS_MANIFEST.json

