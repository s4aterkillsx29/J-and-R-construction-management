venv/
env/

# Runtime data and local-only files (never commit business DB or install state)
data/*
!data/README_KEEP.txt
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
logs/
backups/*.zip

# Business admin inbox copies (runtime sync from Dropbox — not source code)
