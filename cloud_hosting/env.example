# J&R Construction Manager v7.1 primary live environment
JRC_PUBLIC_HOST_MODE=1
JRC_CLOUD_PRIMARY_MODE=1
JRC_DATA_DIR=/var/data/jrc
JRC_SECRET_KEY=replace-with-a-long-random-secret
JRC_INITIAL_ADMIN_PASSWORD=replace-with-a-strong-first-owner-password
JRC_TRUSTED_HOSTS=your-jrc-domain.example.com
JRC_CLOUD_BASE_URL=https://your-jrc-domain.example.com
JRC_DEVICE_COOKIE_SAMESITE=Lax
JRC_SESSION_TIMEOUT_MINUTES=120
JRC_GUNICORN_WORKERS=2
JRC_GUNICORN_THREADS=4
JRC_GUNICORN_TIMEOUT=120

# Stripe Checkout (debit payments with 5% fee)
STRIPE_SECRET_KEY=sk_live_or_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_SUCCESS_URL=https://your-jrc-domain.example.com/payments/complete

# Owner emergency mastery key — remote lockout recovery (never commit real value to git)
JRC_MASTERY_KEY_PASSWORD=replace-with-owner-emergency-key
