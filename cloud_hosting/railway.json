{
  "$schema": "https://railway.app/railway.schema.json",
  "deploy": {
    "startCommand": "gunicorn cloud_hosting.cloud_entry:app --workers ${JRC_GUNICORN_WORKERS:-2} --threads ${JRC_GUNICORN_THREADS:-4} --timeout ${JRC_GUNICORN_TIMEOUT:-120} --bind 0.0.0.0:$PORT",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "environments": {
    "production": {
      "variables": {
        "JRC_PUBLIC_HOST_MODE": "1",
        "JRC_CLOUD_PRIMARY_MODE": "1",
        "JRC_DATA_DIR": "/var/data/jrc"
      }
    }
  }
}